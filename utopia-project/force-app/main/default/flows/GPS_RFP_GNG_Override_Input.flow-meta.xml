    <decisions>
        <name>Determine_Team_Category</name>
        <label>Determine Team Category</label>
        <locationX>534</locationX>
        <locationY>458</locationY>
        <defaultConnector>
            <targetReference>Loop_Override_Requests</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Executive_Committee</name>
            <conditionLogic>1 AND (2 OR 3)</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Override_Requests.Team_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Executive Committee</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Override_Requests.GPS_Project__r.GPS_Project_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Sales Rationale In-Progress</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Override_Requests.GPS_Project__r.GPS_Project_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Sales Rationale Requested</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Committee_srAuth</targetReference>
            </connector>
            <label>Executive Committee</label>
        </rules>
        <rules>
            <name>Sales_Team</name>
            <conditionLogic>1 AND (2 OR 3)</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Override_Requests.Team_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sales Team</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Override_Requests.GPS_Project__r.GPS_Project_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sales Rationale In-Progress</stringValue>
