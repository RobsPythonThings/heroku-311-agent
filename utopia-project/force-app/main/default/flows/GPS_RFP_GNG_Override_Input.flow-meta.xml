                <rightValue>
                    <stringValue>Sales Rationale Requested</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Committee_Vote</targetReference>
            </connector>
            <label>Sales Team</label>
        </rules>
