        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Build_SingleAssignment</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Safe</defaultConnectorLabel>
        <rules>
            <name>Yes_has_both_topics</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_ProblemEntityIds</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>Loop_1.EntityId</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_1</targetReference>
            </connector>
            <label>Yes has both topics</label>
        </rules>
    </decisions>
    <environments>Default</environments>
