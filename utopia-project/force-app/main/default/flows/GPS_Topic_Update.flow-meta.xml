    <recordLookups>
        <name>Get_All_Entities</name>
        <label>Get All Entities</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Duplicates</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>EntityId</field>
            <operator>In</operator>
            <value>
                <elementReference>var_AllEntityIds</elementReference>
            </value>
        </filters>
        <filters>
            <field>TopicId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>NewTopicId</elementReference>
            </value>
        </filters>
        <object>TopicAssignment</object>
        <outputReference>col_ExistingDuplicates</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>EntityId</queriedFields>
    </recordLookups>
