<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>55.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Update_Formula</name>
        <label>Update Formula</label>
        <locationX>176</locationX>
        <locationY>311</locationY>
        <assignmentItems>
            <assignToReference>$Record.Cloud_Formula__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Cloud__c</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <description>updated to only run when record is new or cloud is changed</description>
    <environments>Default</environments>
    <interviewLabel>User - On Create/Update Record Triggered flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>User - On Create/Update Record Triggered flow</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Formula</targetReference>
        </connector>
        <filterFormula>NOT(ISNULL({!$Record.Cloud__c}))
&amp;&amp; (ISNEW() || ISCHANGED({!$Record.Cloud__c}))</filterFormula>
        <object>User</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
