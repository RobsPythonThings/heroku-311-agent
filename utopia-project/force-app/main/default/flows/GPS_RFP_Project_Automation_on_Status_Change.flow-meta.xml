    <textTemplates>
        <name>ttEmailOrgSurvey</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Thank you for engaging the Salesforce.org RFP team.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;The RFP Project &lt;/span&gt;&lt;a href=&quot;{!fxProjectURL}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;font-size: 14px;&quot;&gt;{!$Record.ProjectName__c}&lt;/a&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt; has been completed.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Please take a few minutes to complete a short survey about working with our team: &lt;/span&gt;&lt;a href=&quot;https://forms.gle/J8FDMWvZvmscCVQDA&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;font-size: 14px;&quot;&gt;https://forms.gle/J8FDMWvZvmscCVQDA&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Good luck in the next stage. We look forward to working with you again in the future!&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Regards,&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Salesforce.org RFP Team&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>ttSelfServiceDotOrg</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Thank you for engaging the Salesforce.org RFP Team.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Based on the guidelines we used to determine the priority assigned to support requests, we have categorized &lt;/span&gt;&lt;a href=&quot;{!fxProjectURL}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;font-size: 14px;&quot;&gt;RFP Project {!$Record.Name} &lt;/a&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;as &lt;/span&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;em&gt;Self Service&lt;/em&gt;&lt;/strong&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;, where the Sales Team is responsible for all aspects of the response.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Please visit &lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(17, 85, 204);&quot;&gt;Salesforce.org RFP Central Spot&lt;/span&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt; and &lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(17, 85, 204);&quot;&gt;#sfdo-rfp-support&lt;/span&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt; Slack channel where you will find tools, templates, and more to assist you in completing proposal responses.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Good luck in the next stage.  We look forward to working with you again in the future!&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Regards,&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Salesforce.org RFP Team&lt;/span&gt;&lt;/p&gt;</text>
