    <decisions>
        <name>Action</name>
        <label>Action</label>
        <locationX>512</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>Do Nothing</defaultConnectorLabel>
        <rules>
            <name>Project_Finalized</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Submitted</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Completion_Date</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Project Finalized</label>
        </rules>
        <rules>
            <name>Org_Send_to_Self_Service</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status_c__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Directed to Self Service</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Cloud__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Salesforce.org</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Self_Service_Email_to_Org_Creator</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>.Org Send to Self Service</label>
        </rules>
    </decisions>
