            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>GNG_Committee__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>getProjectId</name>
        <label>getProjectId</label>
        <locationX>776</locationX>
        <locationY>182</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>descision_ScoreBelowThreshold</targetReference>
        </connector>
        <filterLogic>(1 AND 2) AND ( (3 AND 4) OR (5 AND 6) OR (7 AND 8) )</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>projectId</elementReference>
            </value>
        </filters>
        <filters>
            <field>GPS_Project_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>GNG Review</stringValue>
            </value>
        </filters>
        <filters>
            <field>Cloud__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Public Sector</stringValue>
            </value>
        </filters>
        <filters>
            <field>GNG_score__c</field>
            <operator>LessThan</operator>
            <value>
                <numberValue>150.0</numberValue>
            </value>
        </filters>
        <filters>
            <field>Cloud__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>NGO</stringValue>
            </value>
        </filters>
        <filters>
            <field>GNG_score__c</field>
            <operator>LessThan</operator>
            <value>
                <numberValue>70.0</numberValue>
            </value>
        </filters>
        <filters>
            <field>Cloud__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>EDU</stringValue>
            </value>
        </filters>
        <filters>
            <field>GNG_score__c</field>
            <operator>LessThan</operator>
            <value>
                <numberValue>150.0</numberValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>avnio__Project__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
