        <description>gets all &quot;Active&quot; rows from GNG Committee Object</description>
        <name>getCommitteeMembers</name>
        <label>getCommitteeMembers</label>
        <locationX>1009</locationX>
        <locationY>982</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>committeeMembers</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Active__c</field>
            <operator>EqualTo</operator>
