    <decisions>
        <description>For Public Sector and EDU = 150 minimum
For NGO = 70 minimum</description>
        <name>descision_ScoreBelowThreshold</name>
        <label>descision_ScoreBelowThreshold</label>
        <locationX>768</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Threshold Exceeded</defaultConnectorLabel>
        <rules>
            <name>belowThreshold</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>getProjectId.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>assignAE</targetReference>
            </connector>
            <label>belowThreshold</label>
        </rules>
        <rules>
            <name>aboveThreshold</name>
