    <decisions>
        <name>Is_running_user_assigned_the_review</name>
        <label>Is running user assigned the review?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>ErrorMessage</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>(1 AND 2) OR (3 AND 4) OR (5 AND 6) OR 7</conditionLogic>
            <conditions>
                <leftValueReference>RunningUser18DigitId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_Knowledge_Review.Record_Owner__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Knowledge_Review.Validation_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Review by Owner</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>RunningUser18DigitId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_Knowledge_Review.Primary_Reviewer__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Knowledge_Review.Validation_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Review by Primary Reviewer</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>RunningUser18DigitId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_Knowledge_Review.Secondary_Reviewer__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Knowledge_Review.Validation_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Review by Secondary Reviewer</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varIsUserAContentManager</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Pending_Approvals</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
