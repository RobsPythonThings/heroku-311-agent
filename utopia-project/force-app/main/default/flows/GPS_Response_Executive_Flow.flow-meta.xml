        <value>
            <stringValue>Create Response Buckets</stringValue>
        </value>
    </choices>
    <choices>
        <name>Find_Responses_to_Questions</name>
        <choiceText>Find Responses to RFx Requirements</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>Find Responses to Questions</stringValue>
        </value>
    </choices>
