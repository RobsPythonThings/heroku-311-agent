            <targetReference>Lookup_Responses_to_Questions</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Create_Buckets</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Choose_Flow_Path</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Create_Response_Buckets</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Buckets_Flow</targetReference>
            </connector>
            <label>Create Buckets</label>
        </rules>
        <rules>
            <name>Upload_Questions</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Choose_Flow_Path</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Upload_Questions_to_Response_Buckets</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Bulk_Upload_Questions</targetReference>
            </connector>
            <label>Upload Questions</label>
        </rules>
    </decisions>
